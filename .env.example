# ─────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secret
POSTGRES_DB=appdb

# ─────────────────────────────────────
# Authentik – Authorization Server
# ─────────────────────────────────────
AUTHENTIK_SECRET_KEY=supersecretkey-change-in-production-min32

# Public URLs (used by browser)
VITE_AUTHENTIK_URL=http://localhost:9000
VITE_CLIENT_ID=taskmanager-client
VITE_REDIRECT_URI=http://localhost:3000/callback
VITE_API_URL=http://localhost:8000

# Internal URLs (used by backend container)
AUTHENTIK_ISSUER=http://localhost:9000/application/o/taskmanager/
AUTHENTIK_JWKS_URL=http://localhost:9000/application/o/taskmanager/jwks/

# ─────────────────────────────────────
# Backend
# ─────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
